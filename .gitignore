.DS_Store

# Environment / secrets
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/
vendor/
backend/vendor/

# Laravel runtime files
backend/storage/*.key
backend/storage/logs/*
!backend/storage/logs/.gitignore
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/views/*
!backend/storage/framework/cache/.gitignore
!backend/storage/framework/sessions/.gitignore
!backend/storage/framework/views/.gitignore
backend/bootstrap/cache/*.php

# Local databases / test artifacts
backend/database/*.sqlite
backend/database/*.sqlite-*
backend/.phpunit.result.cache

# Frontend cache
frontend/.vite/
frontend/dist/

# Keep backend/public/app committed for cPanel deployment.
